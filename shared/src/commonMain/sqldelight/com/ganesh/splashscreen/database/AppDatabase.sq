CREATE TABLE User (
    username TEXT NOT NULL PRIMARY KEY,
    email TEXT NOT NULL,
    password TEXT NOT NULL,
    mobile TEXT NOT NULL
);

insertUser:
INSERT OR REPLACE INTO User(username, email, password, mobile)
VALUES (?, ?, ?, ?);

getUser:
SELECT * FROM User
WHERE username = ? LIMIT 1;

getAllUsers:
SELECT * FROM User;

deleteUserByUsername:
DELETE FROM User
WHERE username = ?;
